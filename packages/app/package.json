{
  "name": "@kalkulacka-one/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./stores": {
      "types": "./dist/stores/index.d.ts",
      "default": "./dist/stores/index.js"
    },
    "./calculation": {
      "types": "./dist/calculation/index.d.ts",
      "default": "./dist/calculation/index.js"
    },
    "./view-models": {
      "types": "./dist/view-models/index.d.ts",
      "default": "./dist/view-models/index.js"
    },
    "./view-models/server": {
      "types": "./dist/view-models/server/index.d.ts",
      "default": "./dist/view-models/server/index.js"
    },
    "./view-models/client": {
      "types": "./dist/view-models/client/index.d.ts",
      "default": "./dist/view-models/client/index.js"
    },
    "./data-fetching": {
      "types": "./dist/data-fetching/index.d.ts",
      "default": "./dist/data-fetching/index.js"
    },
    "./utilities": {
      "types": "./dist/utilities/index.d.ts",
      "default": "./dist/utilities/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "ncu": "ncu",
    "ncu:upgrade": "ncu -u"
  },
  "dependencies": {
    "@kalkulacka-one/schema": "*",
    "react": "^19.1.1",
    "zod": "^3.22.3",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@kalkulacka-one/typescript-config": "*",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/node": "^22.19.1",
    "@types/react": "^19.1.12",
    "typescript": "^5.9.3"
  },
  "packageManager": "npm@11.5.2"
}
